{
  "manifest_version": 3,
  "name": "Free LeetCode TC Analyzer",
  "version": "1.0",
  "description": "Extracts problem context and code to analyze complexity via a custom Mistral Agent.",

  "permissions": ["activeTab", "storage", "tabs"],

  "background": {
    "scripts": ["background.js"]
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["libs/purify.min.js", "content.js"]
    }
  ],

  "host_permissions": ["https://api.mistral.ai/*"],

  "icons": {
    "24": "icons/icon-24.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "leetcode-tc-analyzer@yourlocaldev.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
